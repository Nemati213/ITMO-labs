<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" styleClass="main-background"
            stylesheets="@../styles/main.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.itmo.nemat.controllers.ScriptConsoleController">

    <children>
        <VBox spacing="5.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label fx:id="terminalTitleLabel" styleClass="table-title" />
                <Label fx:id="fileNameLabel" style="-fx-text-fill: #666666; -fx-font-size: 14px;" />
            </children>
        </VBox>

        <TextArea fx:id="consoleArea" editable="false" wrapText="true"
                  style="-fx-control-inner-background: #1A1A1A; -fx-text-fill: #BDE0C3; -fx-font-family: 'Consolas', 'Courier New', monospace; -fx-font-size: 14px; -fx-border-color: #333333; -fx-border-radius: 5px; -fx-background-radius: 5px;"
                  AnchorPane.bottomAnchor="65.0" AnchorPane.leftAnchor="20.0"
                  AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="85.0" />

        <Button fx:id="closeButton" mnemonicParsing="false" onAction="#onCloseClick" styleClass="command-button"
                AnchorPane.bottomAnchor="20.0" AnchorPane.rightAnchor="20.0" />
    </children>

</AnchorPane>